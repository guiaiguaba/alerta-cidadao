{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs":    ["src/**", "tsconfig.json", "package.json"],
      "outputs":   ["dist/**", ".next/**"]
    },
    "start:dev": {
      "cache":     false,
      "persistent": true
    },
    "dev": {
      "cache":     false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs":    ["src/**", "jest.config.*", "tsconfig.json"],
      "outputs":   ["coverage/**"]
    },
    "test:cov": {
      "dependsOn": ["^build"],
      "outputs":   ["coverage/**"]
    },
    "lint": {
      "inputs":  ["src/**", ".eslintrc*"],
      "outputs": []
    },
    "prisma:migrate": {
      "cache": false
    },
    "prisma:studio": {
      "cache":     false,
      "persistent": true
    }
  }
}
