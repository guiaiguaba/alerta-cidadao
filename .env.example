# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=alertacidadao
POSTGRES_USER=alertauser
POSTGRES_PASSWORD=SenhaSuperSegura123!

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=RedisPass456!

# ─── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=MinioPass789!
# URL pública do MinIO (via Nginx)
STORAGE_PUBLIC_URL=https://storage.alertacidadao.com.br

# ─── Firebase ─────────────────────────────────────────────────
# Cole o JSON completo da service account do Firebase (sem quebras de linha)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=https://iguaba.alertacidadao.com.br,https://admin.alertacidadao.com.br

# ─── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.alertacidadao.com.br
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto

# ─── SSL ──────────────────────────────────────────────────────
