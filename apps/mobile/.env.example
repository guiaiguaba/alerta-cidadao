# Alerta Cidadão — Mobile — Variáveis de Ambiente
# Configuradas via --dart-define no build ou via .env (use flutter_dotenv)
# ============================================================

# ==========================================
# API BACKEND
# ==========================================
# URL base da API (android emulator usa 10.0.2.2 para localhost)
API_BASE_URL=http://10.0.2.2:3000/api/v1
# Produção:
# API_BASE_URL=https://api.alertacidadao.com/api/v1

# ==========================================
# TENANT (pré-configurado por flavor)
# ==========================================
# Pode ser sobrescrito pelo usuário na tela de login
DEFAULT_TENANT_SLUG=demo

# ==========================================
# FLAVOR
# ==========================================
FLAVOR=citizen  # citizen | agent

# ==========================================
# COMANDOS DE BUILD
# ==========================================
# Desenvolvimento:
#   flutter run --flavor citizen --target lib/main_citizen.dart \
#     --dart-define=API_BASE_URL=http://10.0.2.2:3000/api/v1

# Produção:
#   flutter build apk --flavor citizen --target lib/main_citizen.dart \
#     --dart-define=API_BASE_URL=https://api.alertacidadao.com/api/v1 \
#     --release

# ==========================================
# FIREBASE
# ==========================================
# Adicionar google-services.json em:
#   android/app/google-services.json      (Android)
#   ios/Runner/GoogleService-Info.plist   (iOS)
#
# Gerar em: https://console.firebase.google.com/
# Projeto → Configurações → Seus apps → Download config

# ==========================================
# GOOGLE SIGN-IN
# ==========================================
# android/app/src/main/res/values/strings.xml:
# <string name="default_web_client_id">SEU_WEB_CLIENT_ID.apps.googleusercontent.com</string>
