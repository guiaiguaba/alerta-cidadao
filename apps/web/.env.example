# ============================================================
# Alerta Cidadão — Web (Next.js) — Variáveis de Ambiente
# ============================================================

# ==========================================
# NEXTAUTH
# ==========================================
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=substitua_por_string_aleatoria_32_chars

# URL pública da aplicação web (sem trailing slash)
NEXTAUTH_URL=https://iguaba.alertacidadao.com

# ==========================================
# API BACKEND
# ==========================================
# URL interna (server-side) para chamadas ao NestJS
NEXTAUTH_API_URL=http://api:3000/api/v1

# URL pública (client-side, exposta ao browser)
NEXT_PUBLIC_API_URL=https://api.alertacidadao.com/api/v1

# WebSocket (client-side)
NEXT_PUBLIC_WS_URL=wss://api.alertacidadao.com

# ==========================================
# GOOGLE OAUTH
# ==========================================
GOOGLE_CLIENT_ID=seu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_google_client_secret

# ==========================================
# TENANT PADRÃO (para login Google sem subdomínio)
# ==========================================
DEFAULT_TENANT_SLUG=demo

# ==========================================
# NEXT.JS
# ==========================================
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=production
