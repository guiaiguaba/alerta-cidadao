# ============================================================
# Alerta Cidadão API — Variáveis de Ambiente
# Copiar para .env e preencher os valores
# NUNCA commitar o .env no repositório
# ============================================================

# ==========================================
# BANCO DE DADOS
# ==========================================
DATABASE_URL=postgresql://alerta:sua_senha_aqui@localhost:5432/alerta_cidadao
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://localhost:6379
# Para Redis com senha:
# REDIS_URL=redis://:senha@localhost:6379

# ==========================================
# AUTENTICAÇÃO JWT
# ==========================================
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitua_por_string_aleatoria_de_64_chars_minimo
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# ==========================================
# GOOGLE OAUTH (para login com Google)
# ==========================================
# Criar em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu_google_client_id.apps.googleusercontent.com

# ==========================================
# FIREBASE CLOUD MESSAGING (Push Notifications)
# ==========================================
# Obter em: Firebase Console → Project Settings → Service Accounts → Generate new private key
FCM_PROJECT_ID=seu-projeto-firebase
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nconteudo_da_chave\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto.iam.gserviceaccount.com

# ==========================================
# STORAGE — S3 ou MinIO
# ==========================================
S3_ENDPOINT=https://s3.amazonaws.com
# Para MinIO local:
# S3_ENDPOINT=http://localhost:9000
S3_BUCKET=alerta-cidadao-media
S3_REGION=sa-east-1
S3_ACCESS_KEY=sua_access_key
S3_SECRET_KEY=sua_secret_key
# URL pública para acessar arquivos (pode ser CDN)
S3_PUBLIC_URL=https://alerta-cidadao-media.s3.sa-east-1.amazonaws.com

# ==========================================
# SMS — OTP (escolher um provedor)
# ==========================================
# Opções: console (dev), twilio, aws_sns
SMS_PROVIDER=console

# Twilio (se SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=sua_auth_token
TWILIO_FROM_NUMBER=+15551234567

# ==========================================
# APLICAÇÃO
# ==========================================
APP_DOMAIN=alertacidadao.com
PORT=3000
NODE_ENV=development

# Bcrypt: número de rounds (12 = ~250ms, 10 = ~100ms em prod)
BCRYPT_ROUNDS=12

# Chave para API interna (provisionamento de tenant)
# Gerar com: openssl rand -hex 32
INTERNAL_API_KEY=substitua_por_chave_aleatoria_hex_32

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_TTL=60000       # 1 minuto em ms
RATE_LIMIT_MAX=100         # requests por janela

# ==========================================
# CORS (produção)
# ==========================================
# Domínios permitidos separados por vírgula
CORS_ORIGINS=https://alertacidadao.com,https://*.alertacidadao.com
